# ════════════════════════════════════════════════════════════════
# TeleVault — Environment Variables
# Copy this file to .env and fill in your values.
# Author: Deep Joshi · All Rights Reserved
# ════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_string_at_least_32_characters_long
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_from_my_telegram_org
SOURCE_CHAT_NAME=My Media Chat

# ── FOLDER ROUTING ────────────────────────────────────────────────
IMAGE_DEST=/mnt/media/images
VIDEO_DEST=/mnt/media/videos
DOC_DEST=/mnt/media/documents
OTHER_DEST=/mnt/media/other

# ── DOWNLOAD SETTINGS ─────────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=3
MAX_FILE_SIZE_MB=2048
SKIP_DUPLICATES=true
SORT_BY_DATE=true
AUTO_START=false

# ── INTEGRATIONS (leave blank to disable) ────────────────────────
JELLYFIN_URL=
JELLYFIN_API_KEY=
SONARR_URL=
SONARR_API_KEY=
RADARR_URL=
RADARR_API_KEY=

# ── NOTIFICATIONS (optional) ─────────────────────────────────────
NOTIFICATIONS_ENABLED=false
NTFY_URL=
